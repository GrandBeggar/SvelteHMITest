{
  "name": "sveltehmi",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "check": "svelte-check",
    "lint": "prettier --check \"*.{html,js,json}\" \"src/**/*.{css,js,json,svelte}\" \"scripts/**/*.js\" \"test/**/*.js\"",
    "test": "vitest --run",
    "contract:validate": "node scripts/validate-machine-contract.js",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "serve": "node server.js",
    "smoke": "node server.js --smoke"
  },
  "dependencies": {
    "ads-client": "^2.2.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@testing-library/svelte": "^5.3.1",
    "fast-xml-parser": "^5.9.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.0",
    "svelte": "^5.53.12",
    "svelte-check": "^4.6.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.8"
  }
}
